# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional model override (default: gemini-2.5-flash).
# Tip: free-tier keys are limited to ~5 requests/min on gemini-2.5-flash; the
# orchestrator scenario makes 10+ model calls. Use a billing-enabled key for
# the workshop, or try gemini-2.5-flash-lite for higher free-tier limits.
# GEMINI_MODEL=gemini-2.5-flash-lite

# Orchestrator -> worker agent base URLs (defaults shown; override after cloud deploy)
INVENTORY_AGENT_URL=http://localhost:8001
ORDERS_AGENT_URL=http://localhost:8002
PRICING_AGENT_URL=http://localhost:8003
