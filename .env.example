# Local Gemma ONNX model used in-process by every ADK LlmAgent.
GEMMA_MODEL=onnx-community/gemma-4-E4B-it-ONNX
GEMMA_DEVICE=cpu
GEMMA_DTYPE=q4
GEMMA_API_URL=http://localhost:8016
GEMMA_API_HOST=127.0.0.1
GEMMA_API_PORT=8016
TRANSFORMERS_CACHE_DIR=models/transformers-cache
# Set after the first successful model download if you want no network access.
TRANSFORMERS_OFFLINE=false
# Optional Hugging Face-compatible mirror, for example https://hf-mirror.com
HF_ENDPOINT=

# Orchestrator -> worker agent base URLs (defaults shown; override after cloud deploy)
INVENTORY_AGENT_URL=http://localhost:8001
ORDERS_AGENT_URL=http://localhost:8002
PRICING_AGENT_URL=http://localhost:8003
